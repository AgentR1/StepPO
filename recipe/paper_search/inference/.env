# Paper retrieval backend.
# Use local_db for the local Paper Search service, or google for Serper Google Search.
PAPER_AGENT_V2_SEARCH_SOURCE=local_db # [Options: local_db, google]
# API key and base URL for the local Paper Search service.
PAPER_SEARCH_V2_BASE_URL=http://127.0.0.1:4000

# Month range for paper retrieval. Use YYYY-MM or leave empty for no limit.
PAPER_AGENT_V2_PAPER_FROM=
PAPER_AGENT_V2_PAPER_TO=2024-10 
# Optional overrides for backend query parameter names.
PAPER_SEARCH_V2_RANGE_FROM_PARAM=from
PAPER_SEARCH_V2_RANGE_TO_PARAM=to

# PAPER_AGENT_V2_OPENAI_TOOLS=1 (default): send OpenAI ``tools`` + tool_choice=auto. Tool calls are parsed
#   only from ``message.content`` (Hermes), per recipe — we do not rely on ``message.tool_calls``.
#   If you still get HTTP 400 from vLLM, the server is validating/parsing tool output when ``tools`` is set;
#   fix is server-side (vLLM version/flags/tool parser), not the client reading only ``content``.
#   Set to 0 to omit ``tools`` from the request.
# PAPER_AGENT_V2_NATIVE_TOOLS=1: tool_choice=required (strict native tools only).
# PAPER_AGENT_V2_NATIVE_TOOLS=0

# PaperScout policy model endpoint. This should be an OpenAI-compatible chat API.
PAPER_AGENT_V2_API_BASE=http://localhost:8998/v1
PAPER_AGENT_V2_API_KEY=Qwen3-4b-instruct
PAPER_AGENT_V2_MODEL_NAME=Qwen3-4b-instruct

# Optional hosted model endpoint example.
# PAPER_AGENT_V2_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# PAPER_AGENT_V2_API_KEY=sk-d85cf3f774b646659b6fd099b9c7672d
# PAPER_AGENT_V2_MODEL_NAME=qwen3-max

# Selector endpoint for paper relevance scoring.
PAPER_AGENT_V2_SELECTOR_URL=http://localhost:8993/classify
PAPER_AGENT_V2_SELECTOR_MODEL=selector

# Dataset and output.
# Uncomment these paths to run the RealScholarQuery benchmark.
PAPER_AGENT_V2_DATASET=datasets/RealScholarQuery/test.jsonl
PAPER_AGENT_V2_SAVE_DIR=results/realscholar/step-200-4b
# Current lightweight smoke-test dataset and output directory.
# PAPER_AGENT_V2_DATASET=datasets/test_case.jsonl
# PAPER_AGENT_V2_SAVE_DIR=results/test_case/agent-4b
# Number of full retry passes over unfinished samples.
PAPER_AGENT_V2_RETRY_ROUNDS=10
