# Run from repo root with: python recipe/paper_search/inference/run_paper_agent.py
# (or cd into this folder after exporting PYTHONPATH to the repo root).

# --- vLLM policy (same HF folder as training checkpoint) ---
PAPER_SEARCH_INFERENCE_MODEL_PATH=/path/to/Qwen3-4B-Instruct-2507
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=10240
PAPER_SEARCH_INFERENCE_MAX_NEW_TOKENS=8192
PAPER_SEARCH_INFERENCE_TEMPERATURE=0.1
# Tool parser name registered in verl (training rollout multi_turn.format, usually "hermes").
PAPER_SEARCH_TOOL_PARSER=hermes
# Optional JSON kwargs for tokenizer.apply_chat_template, e.g. {"enable_thinking": false}
# PAPER_SEARCH_APPLY_CHAT_TEMPLATE_KWARGS=

# --- Paper Search API (see recipe.paper_search.utils.PaperSearchClient) ---
PAPER_SEARCH_BASE_URL=http://127.0.0.1:4000

# --- Selector HTTP API (host only; client POSTs /classify) ---
PAPERSEARCH_SELECTOR_BASE_URL=http://localhost:8993
PAPERSEARCH_SELECTOR_MODEL_NAME=selector

# --- Batch IO ---
PAPER_AGENT_V2_DATASET=datasets/RealScholarQuery/test.jsonl
PAPER_AGENT_V2_SAVE_DIR=results/realscholar/run
PAPER_AGENT_V2_RETRY_ROUNDS=10
# Optional: more agent steps than training default (5) without code changes.
PAPER_SEARCH_INFERENCE_MAX_STEPS=15
